$omp=28
[ T i t l e ]
tron series

[Parameters]
 icntl    =          0     # (D=0) 3:ECH 5:NOR 6:SRC 7,8:GSH 11:DSH 12:DUMP
 maxcas   =      1000000      # (D=10) number of particles per one batch
 maxbch   =        50   # (D=10) number of batches
 file(1)  = c:/phits        # (D=c:/phits) PHITS install folder name
$  required options for DCHAIN 
 file(21) = c:/phits/dchain-sp/data # (D=c:/phits/dchain-sp/data) DCHAIN data folder
 jmout    =           1     # (D=0) Density echo, 0:input, 1:number density
 e-mode   =           0     # (D=0) Event generator mode is not recommended for DCHAIN
$ recommended option for isomer production
 igamma   =           3     # (D=2) 0:No, 1:Old, 2:EBITEM, 3:EBITEM+Isomer
 nlost    =         10E6
 istdev   =         -1
 dmax(2)  =         400
$ 다시전산모사하려면 istdev = -1 추가
MDBATIMA = 5000

[ S o u r c e ]
   s-type =   2             # mono-energetic axial source
     proj =   6000012        # c-12         
      dir =   0.707           # z-direction of beam [cosine]
	  phi =   180
	  dom =   0
       x0 =   528
       x1 =   548
       y0 =   -2395
       y1 =   -2375
       z0 =   -1758
	   z1 =   -1758
	   e0 = 419.42 # 419.42 MeV mono-energy, MeV/u
	
