[T-DCHAIN]
  title = No.1 phantom (xyz)
  mesh = reg
   reg = 301 
  file = reg_301_20s.out   # file name of dchain input file
  timeevo =  2               # time evolution / irradiation schedule
    20 s 1.0
	4 h 0.0 
  outtime = 2               # output times
    20 s
   -4 h 
  amp = 145656000              # (D=1.0) Source Intensity(source/sec)
  idivs = 5                 # (D=50) number of calculation substebs used in irradiation
  iphtout = -2               # (D=1) 2 = separate [Source] output to files for each time
  ipltmode = 1

