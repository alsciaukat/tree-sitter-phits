$ -*- mode: phits-inp-ts; coding: utf-8; -*-

$omp=20

[Title]
KIRAMS radiation test on May 16


[Parameters]
icntl    = 0     $ 0: Normal simulation
maxcas   = 50000000     $ Number of histories per batch
maxbch   = 200     $ Number of batches
e-mode   = 0
negs     = 1
jmout    = 1
igamma   = 3 $ D=2
ngem     = 2 $ !IMPORTANT Use GEM ver 2.
istdev   = 1      $ Calculate standard deviation across batches
mdbatima = 5000

[Source]
$ <source> = 9
$--- 26 MeV Proton beam ---
$ +y direction, beam origin = (x = 0 cm, y = 0 cm, z = 14.5 cm)
s-type  =  3              $ Gaussian shaped source
proj    =  proton         $ Projectile particle
x0      =   0.0           $ Beam center X
x1      =   0.5           $ FWHM in x
y0      =   2.0           $ Beam center Y
y1      =   0.5           $ FWHM in y
z0      =  14.5           $ beam center z
z1      =   0.5           $ FWHM in z
dir     =   0             $ 90 degrees from the z axis (cos(90°) = 0)
phi     =   90            $ 90 degrees from the x axis in the xy plane
dom     =   0.1           $ 0.1 steradian angular variance (practically none)
e-type  = 2               $ Gaussian energy distribution
eg0     = 26              $ (MeV) Bean energy
eg1     = 1               $ (MeV) Standard deviation of energy
eg2     = 22              $ Minimum energy cutoff
eg3     = 30              $ Maximum energy cutoff

$ <source> = 1
$ s-type  =  3
$ proj    =  proton         $ Projectile
$ x0      =   0.0           $ Beam center X
$ x1      =   0.5           $ FWHM in x
$ y0      =   0.0           $ Beam center Y
$ y1      =   0.5           $ FWHM in y
$ z0      =  14.5           $ beam center z
$ z1      =   0.5           $ FWHM in z
$ dir     =   0             $ 90 degrees from the z axis (cos(90°) = 0)
$ phi     =   90            $ 90 degrees from the x axis in the xy plane
$ dom     =   0.1
$ e-type  = 3
$ et0     = 0.001
$ et1     = 0.00001
$ et2     = 0.1


[ Material ]
$==============================================================
$  mat 1  Be      beryllium target
$  mat 2  Al      aluminum beamline structure
$  mat 3  C       graphite collimator
$  mat 4  Concrete + Eu  46.56 ug  (top)
$  mat 5  Concrete + Eu 216.99 ug  (left)
$  mat 6  Concrete + Eu 431.27 ug  (right)
$  mat 7  PMMA    acrylic specimen case
$  mat 8  SUS304  stainless steel table
$  mat 9  Air     dry air at STP
$  mat 10 Gold    gold foil specimen
$  Trace element reference: NIST SRM 1d (Trace Elements in Concrete)
$==============================================================

