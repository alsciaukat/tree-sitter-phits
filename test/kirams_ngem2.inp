        18000  -0.013000    $ Ar (natural)

$--- mat 10: Gold ---
$    rho = -19.32 g/cm^3
mat[10]
        79000    1.0

[ Surface ]
$--- Be Target (cylinder, R=1.5 cm, axis along y) ---
$ Infinite cylinder along y at (x=0, z=14.5)
 101  C/Y   0.0   14.5   1.5      $ Be target outer surface R=1.5 cm
 102  PY    5.0                    $ Be target downstream face  (y=5.0 cm)
 103  PY    4.5                    $ Be target upstream face (y=4.5 cm)

$--- Al Case (annular cylinder, R_in=1.5 cm, R_out=4.5 cm) ---
 111  C/Y   0.0   14.5   4.5      $ Al case outer surface R=4.5 cm
 112  C/Y   0.0   14.5   1.5      $ Al case inner bore R=1.5 cm  (= surf 101)
 113  PY    6.6                    $ Al case downstream face   (y=6.6 cm)
 114  PY    4.4                    $ Al case upstream face (y=4.4 cm)
$ Note: surf 112 is geometrically identical to surf 101;
$       reference surf 101 directly in cell cards for the bore.

$--- Collimator (carbon, stepped annular body) ---
$    Pad002 (outer collar): R_in=1.0cm, R_out=2.75cm, y=6.6 - 7.5cm
$    Pad003 (inner tube):   R_in=1.0cm, R_out=1.5cm,  y=4.1 - 7.5cm
$    Step at y=6.6cm: outer radius increases from 1.5 to 2.75 cm
 121  C/Y   0.0   14.5   2.75     $ Collimator outer radius (Pad002), R=2.75 cm
 122  C/Y   0.0   14.5   1.5      $ Collimator step radius (Pad002 inner = Pad003 outer)
 123  C/Y   0.0   14.5   1.0      $ Collimator bore R=1.0 cm
 124  PY    7.5                    $ Collimator downstream face (y=7.5 cm)
 125  PY    6.6                    $ Collimator step plane   (y=6.6 cm)
 126  PY    5.0                    $ Collimator upstream face (y=4.1 cm)


$=== 조사실 시설 외 물질 ==================================================================================
$--- Specimen Case (시편 케이스) ---
$    Three cylinders R=1.6 cm, thickness 1.5 mm (y=9.85~10.0 cm)
$    Centers: (0,14.5)z=16.75, (±1.9486, 13.375) cm in x-z plane
 201  C/Y   0.0      16.75    1.6   $ Specimen case of 10 ppm specimen (top) 10 ppm
 202  C/Y  -1.9486   13.375   1.6   $ Specimen case for 50 ppm specimen (left) 50 ppm
 203  C/Y   1.9486   13.375   1.6   $ Specimen case hole 100 ppm specimen (right) 100 ppm
 204  PY   12.5                     $ Specimen case downstream face   (y=10.0 cm) + shift 2.5 cm
 205  PY   12.35                    $ Specimen case upstream face (y=9.85 cm) + shift 2.5 cm

$--- Concrete Specimen (콘크리트 시편) ---
$    Same three cylinder positions, thickness 2.7 mm (y=9.58~9.85 cm)
$ (reuses surfs 201, 202, 203 for cylinder walls)
 211  PY   12.066                    $ 10 ppm Concrete specimen upstream face 0.284 cm
 212  PY   12.055                    $ 50 ppm Concrete specimen upstream face 0.295 cm
 213  PY   12.076                    $ 100 ppm Concrete specimen upstream face 0.274 cm
$ Note: upstream face is surf 205

$--- Gold Specimen (금박 시편) ---
$    mass 1.36 (5) mg, diameter 3.3 (1) mm
$    calculated thickness 2.058 (146) um
$ (reuses surfs 204)
221   PY   12.499794
222   C/Y  0.0   14.5   0.165
$=============================================================================================

$--- Stainless Steel Table (Extrude005) ---
$    Rectangular slab: x=[-25,25], y=[0,300], z=[-1.0, 0.0] cm
 301  PX   25.0                    $ Table +x face
 302  PX  -25.0                    $ Table -x face
 303  PY  50.0                    $ Table +y face (far end)
 304  PY    0.0                    $ Table upstream/beam-entrance face
 305  PZ    0.0                    $ Table top surface    (z=0)
 306  PZ   -1.0                    $ Table bottom surface (z=-1.0 cm)

$--- Outer void boundary ---
 999  RPP   -10.0 10.0 0.0 12.7 4.5 24.5


[ Cell ]
$--- Cell 1: Be Target ---
$    inside cyl 101 (-101), below upstream plane 102 (-102), above downstream plane 103 (103)
  1  1  -1.848  -101 -102  103    $ Be target (rho=-1.848 g/cm^3)

$--- Cell 2: Al Case (annular body) ---
$    Anuulus surrounding beryllium target
$     inside outer cyl 111 (-111), outside bore cyl 101 (101),
$     below upstream plane 113 (-113), above downstream plane 114 (114)
$    or
$    Disc blocking proton upstream
$      inside outer cyl 111 (-111), outside bore cyl 101 (101),
$      below upstream plane 103 (-103), above downstream plane 114 (114)
  2  2  -2.700  (-111  101 -113  114):(-101 -103 114)    $ Al case annular body (rho=-2.700 g/cm^3)

$--- Cell 3: Al Case bore — air gap (inside bore, outside Be target region) ---
$    inside cyl 101 (-101), between planes 114..113,
$    excluding the Be target slab: require above 102 OR below 103
$  3  0             $ Air inside Al bore

$--- Cell 4: Collimator (carbon) ---
$    Outer collar
$      inside outer cyl 121 (-121), outside step cyl 122 (122),
$      between step plane 125 and downstream face 124
$    or
$    Inner tube
$      inside step cyl 122 (-122), outside inner cyl 123 (123),
$      between upstream plane 126 and downstream face 124
  4  3  -2.000  (-121 122 -124 125):(-122 123 -124 126)    $ Collimator outer collar (rho=-2.0 g/cm^3, C)

$--- Cell 6a: Gold specimen ---
$    cylinder with thickness 2.058 (146) um
$      inside cyl 222 (-222)
$      between upstream plane 221 and downstream face 204
  6  10  -19.32        -222 -204 221         $ Air inside collimator bore

$--- Cell 7: Concrete specimens (3 cylinders) ---
$    inside any of the 3 specimen cylinders (union: -201:-202:-203),
$    between upstream plane 205 (-205) and downstream plane 211 (211)
  7  4  -1.74   -201 -205  211   $ Concrete specimens 10 ppm (top)
  8  5  -1.78   -202 -205  212   $ Concrete specimens 50 ppm (left)
  9  6  -1.71   -203 -205  213   $ Concrete specimens 100 ppm (right)

$--- Cell 8: Specimen Case plate (PMMA acrylic) ---
$    Same 3 cylinders as concrete (surfs 201, 202, 203), shifted downstream.
$    Between downstream plane 205 (205) and upstream plane 204 (-204).
  10  7  -1.190  (-201:-202:-203) -204  205   $ PMMA specimen case (rho=-1.190 g/cm^3)


$--- Cell 9: Stainless Steel Table ---
  11  8  -8.0  -301  302 -303  304 -305  306   $ Stainless table (rho=-8.0 g/cm^3)

$--- Cell 100: Room air (all space inside boundary not already assigned) ---
 100  9  -1.293e-3  -999  #1 #2 #4 #6 #7 #8 #9 #10 #11   $ Dry air (rho=-1.293e-3 g/cm^3)

$--- Cell 9999: Outside simulation boundary ---
9999  -1   999   $ Outer void


