$omp=20
[Title]
KIRAMS passive dosimeter bundles: 200 cm from collimator downstream end
[Parameters]
icntl    = 0
maxcas   = 300000
maxbch   = 10000
e-mode   = 0
negs     = 1
jmout    = 1
igamma   = 3
nlost    = 10E6
istdev   = 1
dmax(2)  = 400
mdbatima = 5000
nucdata  = 1
inclg    = 1
einclmin = 1.0
einclmax = 3000.0
[Source]
$ 26 MeV proton beam incident on 5-mm Be target.
$ Beam direction: +y.
$ Source is defined as a rectangular plane 0.5 cm upstream of the Be target.
$ Be target: y = 4.5 to 5.0 cm; source plane: y = 4.0 cm.
$ Passive dosimeter front surface is placed at y = 207.5 cm,
$ i.e., 200 cm downstream from collimator end at y = 7.5 cm.
s-type  =  2
proj    =  proton
x0      =  -0.25
x1      =   0.25
y0      =   4.0
y1      =   4.0
z0      =  14.25
z1      =  14.75
dir     =   0.0
phi     =   90.0
dom     =   0.0
e0      =  26.0


[Material]
