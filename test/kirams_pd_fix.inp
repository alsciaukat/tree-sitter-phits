xmax   =  0.25
y-type = 2
ny     = 120
ymin   = 3.5
ymax   = 8.5
z-type = 2
nz     = 120
zmin   = 12.0
zmax   = 17.0
e-type = 3
ne     = 40
emin   = 1.0e-3
